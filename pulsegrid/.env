PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pulsegrid
DB_USER=postgres
DB_PASSWORD=Akash26

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
# JWT — change this to a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=pulsegrid_super_secret_change_in_prod
JWT_EXPIRES_IN=7d



# # ─────────────────────────────────────────────────────────────────
# # PulseGrid — Environment Variables
# # Copy this file to .env and fill in your values.
# # NEVER commit .env to git.
# # ─────────────────────────────────────────────────────────────────

# # Server
# PORT=3000
# NODE_ENV=development          # development | production | test

# # ─── Frontend URL (CORS) ─────────────────────────────────────────
# # Set this in Railway after deploying your Vercel dashboard
# FRONTEND_URL=http://localhost:3001
# # FRONTEND_URL=https://pulsegrid.vercel.app   # uncomment in production
# # FRONTEND_URL_PREVIEW=https://pulsegrid-git-main.vercel.app   # optional

# # ─── PostgreSQL (local dev) ───────────────────────────────────────
# # In production on Railway, DATABASE_URL is injected automatically.
# # These are only used when DATABASE_URL is NOT set.
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pulsegrid
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# # ─── Redis (local dev) ────────────────────────────────────────────
# # In production on Railway, REDIS_URL is injected automatically.
# # These are only used when REDIS_URL is NOT set.
# REDIS_HOST=localhost
# REDIS_PORT=6379

# # ─── JWT ──────────────────────────────────────────────────────────
# # Generate a strong secret:
# # node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET=change_this_to_a_long_random_string_in_production
# JWT_EXPIRES_IN=7d

# # ─── Railway (production only — set in Railway dashboard) ─────────
# # DATABASE_URL=postgresql://user:pass@host:port/db   (auto-injected)
# # REDIS_URL=redis://default:pass@host:port           (auto-injected)
